  "model_overrides": {
    "planner": "opus",
    "executor": "sonnet",
    "reviewer": "sonnet",
    "analyzer": "opus",
    "analyzer_update": "sonnet",
    "doc_updater": "sonnet",
    "template_extractor": "opus",
    "template_applier": "sonnet"
  }
}
